# Supabase — obtén estos valores en supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Backend (NO exponer en el cliente — sin prefijo VITE_)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... # Supabase → Settings → API → service_role

# Anthropic (backend serverless)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (backend serverless — solo para TTS)
OPENAI_API_KEY=sk-...

# Web Push (backend serverless)
VAPID_PUBLIC_KEY=BH...
VAPID_PRIVATE_KEY=kL...
VAPID_EMAIL=mailto:tuemail@dominio.com
# La pública también va como VITE_VAPID_PUBLIC_KEY para que el cliente suscriba
VITE_VAPID_PUBLIC_KEY=BH...

# Cron + snooze (backend serverless)
CRON_SECRET=generar-con-openssl-rand-hex-32
SNOOZE_SECRET=generar-con-openssl-rand-hex-32  # Opcional, cae a CRON_SECRET si falta

# Config opcional
TTS_DAILY_CHAR_LIMIT=25000  # Chars TTS por usuario/día. Default 25000 (~$0.375 max)
