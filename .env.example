# Supabase — obtén estos valores en supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# Resend — envío de emails OTP desde nuestro dominio (obligatorio para el login con código)
# Obtén la API key en resend.com → API Keys
# EMAIL_FROM debe usar un dominio verificado en Resend (Resend → Domains)
RESEND_API_KEY=re_...
EMAIL_FROM=Focus <noreply@usefocus.me>

# Anthropic (backend serverless — NO exponer en el cliente)
ANTHROPIC_API_KEY=sk-ant-...

# API pública usada por la app iOS nativa para hablar con Vercel
VITE_API_ORIGIN=https://www.usefocus.me

# Web Push / cron
VITE_VAPID_PUBLIC_KEY=...
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=mailto:admin@usefocus.me
CRON_SECRET=...

# APNs para app iOS nativa
APNS_TEAM_ID=...
APNS_KEY_ID=...
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APNS_BUNDLE_ID=me.usefocus.app
APNS_ENV=production
VITE_APNS_ENV=production
